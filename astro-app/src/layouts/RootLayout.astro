---
import "@/styles/globals.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Openmesh Network — Permissionless & Immutable Cloud",
  description = "Storing the world's important data without a middleman. The decentralized cloud network for Web3 infrastructure.",
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#ffffff" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
